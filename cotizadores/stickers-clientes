<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Calculadora de Stickers | SINIY</title>

  <script src="components.js"></script>

  <style>
    :root {
      --principal: #5e17eb;
      --gris: #f4f4f4;
      --oscuro: #1a1a1a;
    }

    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background-color: var(--gris);
      color: var(--oscuro);
    }

    h1 {
      text-align: center;
      color: var(--principal);
      margin-top: 2rem;
    }

    /* Banner Publicidad */
    .banner-publicidad {
      width: 100%;
      max-width: 1100px;
      height: 120px;
      margin: 20px auto;
      background: linear-gradient(135deg, #5e17eb, #7c3aed);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: bold;
      font-size: 1.2rem;
      letter-spacing: 1px;
    }

    .controls {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.5rem;
      margin: 2rem 1rem;
    }

    .controls div {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .controls input {
      width: 100px;
      padding: 0.5rem;
      font-size: 1rem;
      margin-top: 0.5rem;
      border-radius: 6px;
      border: 1px solid #ccc;
      text-align: center;
    }

    .resultado {
      text-align: center;
      background: white;
      max-width: 500px;
      margin: 2rem auto;
      padding: 2rem;
      border-radius: 12px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    .precio {
      font-size: 2rem;
      font-weight: bold;
      color: var(--principal);
      margin-top: 1rem;
    }

    /* Botón WhatsApp flotante */
    .whatsapp-float {
      position: fixed;
      bottom: 20px;
      right: 20px;
      background: #25D366;
      color: white;
      font-size: 24px;
      width: 60px;
      height: 60px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      box-shadow: 0 5px 15px rgba(0,0,0,0.3);
      z-index: 999;
    }

    .whatsapp-float:hover {
      transform: scale(1.1);
    }

    @media (max-width: 600px) {
      .banner-publicidad {
        height: 90px;
        font-size: 1rem;
      }
    }

  </style>
</head>

<body>

  <siniy-header></siniy-header>

  <div class="banner-publicidad">
    ESPACIO PUBLICITARIO DISPONIBLE
  </div>

  <h1>Calcula el Precio de tus Stickers</h1>

  <div class="controls">
    <div>
      <label>Ancho (cm)</label>
      <input type="number" id="ancho" value="4" min="1" oninput="calcular()">
    </div>

    <div>
      <label>Alto (cm)</label>
      <input type="number" id="alto" value="4" min="1" oninput="calcular()">
    </div>

    <div>
      <label>Cantidad</label>
      <input type="number" id="cantidad" value="100" min="1" oninput="calcular()">
    </div>
  </div>

  <div class="resultado">
    <div>Precio total estimado:</div>
    <div class="precio" id="total">$0</div>
  </div>

  <!-- Botón flotante WhatsApp -->
  <a id="btnWhatsapp" class="whatsapp-float" target="_blank">💬</a>

  <siniy-footer></siniy-footer>

  <script>
    const PRECIO_M2 = 65000;

    function calcular() {
      const ancho = parseFloat(document.getElementById("ancho").value);
      const alto = parseFloat(document.getElementById("alto").value);
      const cantidad = parseInt(document.getElementById("cantidad").value);

      if (ancho <= 0 || alto <= 0 || cantidad <= 0) return;

      const areaStickerM2 = (ancho * alto) / 10000;
      const areaTotal = areaStickerM2 * cantidad;
      const total = areaTotal * PRECIO_M2;

      document.getElementById("total").innerText =
        "$" + total.toLocaleString("es-CO");
    }

    function actualizarWhatsapp() {
      const ancho = document.getElementById("ancho").value;
      const alto = document.getElementById("alto").value;
      const cantidad = document.getElementById("cantidad").value;
      const total = document.getElementById("total").innerText;

      const mensaje = `Hola SINIY 👋 quiero cotizar stickers de ${ancho}cm x ${alto}cm en cantidad de ${cantidad}. Total estimado: ${total}`;
      const url = `https://wa.me/573237028814?text=${encodeURIComponent(mensaje)}`;

      document.getElementById("btnWhatsapp").href = url;
    }

    function init() {
      calcular();
      actualizarWhatsapp();
    }

    document.querySelectorAll("input").forEach(input => {
      input.addEventListener("input", () => {
        calcular();
        actualizarWhatsapp();
      });
    });

    window.onload = init;
  </script>

</body>
</html>
